# Copy to `.env` (git-ignored) before `docker compose up --build`.
# docker compose reads these for ${VAR} substitution in docker-compose.yml.
#
# Reads (balances, policy, live events) work with no secrets at all.
# Only create-wallet and set-limit need the relayer + agent keys.

SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SIM_SOURCE=GAHZHQ2PSDTSJI7MRAWNBDVGUJ5L25OCXIXRXZTOEJB72UDERE2NHORJ

# Funds agent-wallet fees (testnet). Leave blank for read-only.
RELAYER_SECRET=
# Owner key for the demo wallet's policy writes. Leave blank for read-only.
AGENT_SECRET=
AGENT_PUBKEY_HEX=5bdc702e29d1e6816112a3ddaf94e47f0a511f23930b8647a8eee5f869723a11
